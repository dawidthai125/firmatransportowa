# Skopiuj do .env (lokalny dev). NIE używaj projektu wgdom — osobny Supabase!

# 1. https://supabase.com/dashboard → New project (np. transflow-prod)
# 2. Project Settings → General → Project ID
VITE_SUPABASE_PROJECT_ID=your-new-project-ref

# 3. Project Settings → API → Publishable key (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=your-publishable-key

# 4. Edge Function (domyślnie transflow-api)
VITE_SUPABASE_FUNCTION_SLUG=transflow-api

# --- Tylko Supabase Dashboard / GitHub Secrets (NIE w Vercel frontend) ---
# SUPABASE_ACCESS_TOKEN=   → GitHub Actions deploy Edge Functions
# SUPABASE_PROJECT_REF=      → ten sam co VITE_SUPABASE_PROJECT_ID
